AIRFLOW_HOME=/opt/airflow
BIGQUERY_PROJECT=pycontw-225217
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/service-account.json
AIRFLOW__CORE__FERNET_KEY=paste-your-fernet-key-here
# Airflow's docker entrypoint runs `airflow db migrate` on startup unless this is "false".
_AIRFLOW_DB_MIGRATE=false

# Airflow Connections (set via UI or `airflow connections add`)
#
# discord_webhook
#   Used by discord_message_notification Dag (dags/app/discord.py) via HttpHook.
#   Each channel's webhook token (e.g. <id>/<token>) is stored in
#   an Airflow Variable (e.g. discord_webhook_registration_endpoint).
#   conn_type : HTTP
#   host      : https://discord.com/api/webhooks/
#
# Example CLI:
#   airflow connections add discord_webhook --conn-type http --conn-host https://discord.com/api/webhooks/
